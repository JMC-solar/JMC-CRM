rules_version = '2';

// Deny-all: this app is accessed exclusively through the Vercel serverless
// API (server/firestore.ts) using the Firebase Admin SDK, which bypasses
// Security Rules entirely. No client ever talks to Firestore directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
