{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm vite build && pnpm exec esbuild server/_core/app.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "functions": { "api/index.ts": { "maxDuration": 60, "memory": 1024 } },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/storage/:path*", "destination": "/api/index" },
    { "source": "/manus-storage/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
